---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getBaseUrl } from '../utils';

const baseUrl = getBaseUrl();

const projects = [
  { title: 'Project Alpha', description: 'A massive scale data processing pipeline handling terabytes of information daily.', tags: ['React', 'Node.js', 'AWS'], link: '#', category: 'Web' },
  { title: 'Beta App', description: 'A mobile application for field engineers to sync data offline.', tags: ['React Native', 'GraphQL'], link: '#', category: 'Mobile' },
  { title: 'Gamma Dashboard', description: 'Real-time analytics and monitoring dashboard for enterprise clients.', tags: ['Vue.js', 'Firebase'], link: '#', category: 'Web' },
  { title: 'Delta CLI', description: 'Command line tool for rapid project scaffolding and deployment.', tags: ['Go', 'Docker'], link: '#', category: 'OSS' },
  { title: 'Epsilon Design System', description: 'A comprehensive brutalist UI kit for modern web applications.', tags: ['Figma', 'CSS'], link: '#', category: 'Design' },
  { title: 'Zeta Portal', description: 'B2B portal for managing supply chain logistics and inventory.', tags: ['Next.js', 'PostgreSQL'], link: '#', category: 'Web' }
];

const tags = ['All', 'Web', 'Mobile', 'OSS', 'Design'];
---

<BaseLayout title="Projects | CodingCup Labs" description="Explore our portfolio of high-performance software projects.">
  <section class="section container">
    <div class="page-header">
      <h1>OUR WORK</h1>
      <p class="subtitle">A selection of projects demonstrating our commitment to raw performance and uncompromising design.</p>
    </div>

    <div class="filter-bar">
      {tags.map(tag => (
        <button class={`filter-btn ${tag === 'All' ? 'active' : ''}`}>{tag}</button>
      ))}
    </div>

    <div class="projects-grid">
      {projects.map(project => (
        <ProjectCard
          title={project.title}
          description={project.description}
          tags={project.tags}
          link={project.link}
        />
      ))}
    </div>

    <div class="projects-cta mt-xl">
      <div class="cta-box card">
        <h2>HAVE A PROJECT IN MIND?</h2>
        <p>Let's build something brutal.</p>
        <a href={`${baseUrl}/contact`} class="btn btn--primary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-xl) 0;
    border-bottom: 4px solid #000;
  }
  .subtitle {
    font-size: var(--font-body-lg-size);
    color: var(--on-surface-variant);
    max-width: 600px;
    margin: 0 auto;
  }

  .filter-bar {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: var(--spacing-sm) var(--spacing-md);
    background-color: var(--surface);
    border: 2px solid #000;
    font-family: var(--font-label-mono);
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: 2px 2px 0px 0px #000;
    transition: all 0.15s ease;
  }
  .filter-btn:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px 0px #000;
  }
  .filter-btn.active {
    background-color: var(--primary);
    color: var(--on-primary);
    box-shadow: inset 2px 2px 0px 0px rgba(0,0,0,0.5);
    transform: translate(2px, 2px);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: var(--spacing-xl);
  }

  .mt-xl {
    margin-top: 120px;
  }

  .projects-cta {
    text-align: center;
    display: flex;
    justify-content: center;
  }
  .cta-box {
    max-width: 600px;
    background-color: var(--tertiary-container);
    color: var(--on-tertiary-container);
    align-items: center;
  }
  .cta-box h2 {
    color: var(--on-tertiary-container);
    margin-bottom: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
