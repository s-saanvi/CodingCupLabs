---
import { getBaseUrl } from '../utils';

const baseUrl = getBaseUrl();

interface Props {
  title: string;
  description: string;
  pubDate: string;
  author: string;
  tags: string[];
  slug: string;
  cover?: string;
}
const { title, description, pubDate, author, tags, slug, cover } = Astro.props;
---
<article class="card blog-card">
  {cover && (
    <img src={`${baseUrl}${cover}`} alt={`Cover for ${title}`} class="card-img" />
  )}
  <div class="card-content">
    <div class="card-meta">
      <span class="date">{pubDate}</span>
      <span class="author">by {author}</span>
    </div>
    <h3 class="card-title"><a href={`${baseUrl}/blog/${slug}`}>{title}</a></h3>
    <p class="card-desc">{description}</p>
    <div class="card-tags">
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
    <a href={`${baseUrl}/blog/${slug}`} class="read-more">Read more →</a>
  </div>
</article>

<style>
  .blog-card {
    padding: 0;
    overflow: hidden;
  }
  .card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-bottom: 4px solid #000;
  }
  .card-content {
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .card-meta {
    font-family: var(--font-label-mono);
    font-size: 12px;
    color: var(--on-surface-variant);
    margin-bottom: var(--spacing-sm);
    display: flex;
    justify-content: space-between;
  }
  .card-title {
    margin-bottom: var(--spacing-sm);
  }
  .card-title a {
    color: var(--on-surface);
  }
  .card-title a:hover {
    color: var(--tertiary);
  }
  .card-desc {
    flex-grow: 1;
    margin-bottom: var(--spacing-md);
  }
  .card-tags {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-md);
  }
  .read-more {
    font-family: var(--font-label-mono);
    font-weight: bold;
    text-transform: uppercase;
  }
</style>
